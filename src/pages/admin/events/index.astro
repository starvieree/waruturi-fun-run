---
// src/pages/admin/events/index.astro
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabase } from "../../../lib/supabase";

const { data: events, error } = await supabase
  .from("events")
  .select("*, event_categories(name)")
  .order("created_at", { ascending: false });

const { data: categories } = await supabase
  .from("event_categories")
  .select("*")
  .order("name", { ascending: true });
---

<AdminLayout title="Manage Events">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
      <!-- Manage Events -->
    </h1>
    <button
      onclick="openCreateModal()"
      class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors"
    >
      <i class="fas fa-plus mr-2"></i> Add New Event
    </button>
  </div>

  <!-- Error message if any -->
  {
    error && (
      <div class="mb-4 p-4 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 rounded-lg">
        <i class="fas fa-exclamation-circle mr-2" />
        Failed to load events: {error.message}
      </div>
    )
  }

  <div
    class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden"
  >
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
        <thead
          class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400"
        >
          <tr>
            <th class="px-6 py-3">Title</th>
            <th class="px-6 py-3">Category</th>
            <th class="px-6 py-3">Date</th>
            <th class="px-6 py-3">Quota</th>
            <th class="px-6 py-3">Price</th>
            <th class="px-6 py-3">Status</th>
            <th class="px-6 py-3 text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          {
            events && events.length > 0 ? (
              events.map((event) => (
                <tr class="border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/50">
                  <td class="px-6 py-4 font-medium text-gray-900 dark:text-white">
                    {event.title}
                  </td>
                  <td class="px-6 py-4">
                    {event.event_categories?.name || "-"}
                  </td>
                  <td class="px-6 py-4">
                    {event.date_event
                      ? new Date(event.date_event).toLocaleDateString("id-ID")
                      : "-"}
                  </td>
                  <td class="px-6 py-4">{event.quota || "-"}</td>
                  <td class="px-6 py-4">
                    {event.price
                      ? `Rp ${event.price.toLocaleString("id-ID")}`
                      : "Free"}
                  </td>
                  <td class="px-6 py-4">
                    <span
                      class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${event.registration_open ? "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400" : "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400"}`}
                    >
                      {event.registration_open ? "Open" : "Closed"}
                    </span>
                  </td>
                  <td class="px-6 py-4 text-center">
                    <div class="flex items-center justify-center gap-2">
                      <button
                        data-id={event.id}
                        class="edit-btn text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300"
                        type="button"
                      >
                        <i class="fas fa-edit" />
                      </button>
                      <button
                        data-id={event.id}
                        data-title={event.title}
                        class="delete-btn text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300"
                        type="button"
                      >
                        <i class="fas fa-trash" />
                      </button>
                    </div>
                  </td>
                </tr>
              ))
            ) : (
              <tr>
                <td
                  colspan="7"
                  class="px-6 py-4 text-center text-gray-500 dark:text-gray-400"
                >
                  No events found
                </td>
              </tr>
            )
          }
        </tbody>
      </table>
    </div>
  </div>

  <!-- Create Modal -->
  <div
    id="createModal"
    class="fixed inset-0 z-50 hidden overflow-y-auto"
    aria-labelledby="create-modal-title"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0"
    >
      <div
        class="fixed inset-0 bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75 transition-opacity"
        aria-hidden="true"
        onclick="closeCreateModal()"
      >
      </div>
      <span
        class="hidden sm:inline-block sm:align-middle sm:h-screen"
        aria-hidden="true">&#8203;</span
      >

      <div
        class="inline-block overflow-hidden text-left align-bottom transition-all transform bg-white dark:bg-gray-800 rounded-lg shadow-xl sm:my-8 sm:align-middle sm:max-w-5xl sm:w-full"
      >
        <div class="px-6 pt-6 pb-4">
          <div class="flex items-center justify-between mb-4">
            <h3
              class="text-lg font-medium text-gray-900 dark:text-white"
              id="create-modal-title"
            >
              <i class="fas fa-plus mr-2 text-blue-600"></i>
              Create New Event
            </h3>
            <button
              onclick="closeCreateModal()"
              class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300"
              type="button"
            >
              <i class="fas fa-times"></i>
            </button>
          </div>

          <form id="createForm" class="mt-2 space-y-4">
            <!-- Row 1: Title + Slug -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="createTitle"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Title <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="createTitle"
                  name="title"
                  required
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="Event title"
                />
              </div>
              <div>
                <label
                  for="createSlug"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Slug
                </label>
                <input
                  type="text"
                  id="createSlug"
                  name="slug"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="auto-generated"
                />
                <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">
                  Leave blank to auto-generate
                </p>
              </div>
            </div>

            <!-- Row 2: Category + Date -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="createCategory"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Category <span class="text-red-500">*</span>
                </label>
                <select
                  id="createCategory"
                  name="category_id"
                  required
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                >
                  <option value="">Select Category</option>
                  {
                    categories &&
                      categories.map((cat) => (
                        <option value={cat.id}>{cat.name}</option>
                      ))
                  }
                </select>
              </div>
              <div>
                <label
                  for="createDate"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Event Date <span class="text-red-500">*</span>
                </label>
                <input
                  type="date"
                  id="createDate"
                  name="date_event"
                  required
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                />
              </div>
            </div>

            <!-- Row 3: Time + Location -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="createStartTime"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Start Time
                </label>
                <input
                  type="time"
                  id="createStartTime"
                  name="start_time"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                />
              </div>
              <div>
                <label
                  for="createLocation"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Location
                </label>
                <input
                  type="text"
                  id="createLocation"
                  name="location"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="Event location"
                />
              </div>
            </div>

            <!-- Row 4: Quota + Price -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="createQuota"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Quota
                </label>
                <input
                  type="number"
                  id="createQuota"
                  name="quota"
                  min="1"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="Max participants"
                />
              </div>
              <div>
                <label
                  for="createPrice"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Price (Rp)
                </label>
                <input
                  type="number"
                  id="createPrice"
                  name="price"
                  min="0"
                  step="1000"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="0 = Free"
                />
              </div>
            </div>

            <!-- Row 5: Maps + Banner -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="createMaps"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Google Maps Link
                </label>
                <input
                  type="url"
                  id="createMaps"
                  name="maps"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="https://maps.google.com/..."
                />
              </div>
              <div>
                <label
                  for="createBanner"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Banner URL
                </label>
                <input
                  type="url"
                  id="createBanner"
                  name="banner"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="https://example.com/banner.jpg"
                />
              </div>
            </div>

            <!-- Row 6: Description (full width) -->
            <div>
              <label
                for="createDescription"
                class="block text-sm font-medium text-gray-700 dark:text-gray-300"
              >
                Description
              </label>
              <textarea
                id="createDescription"
                name="description"
                rows="3"
                class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                placeholder="Event description"></textarea>
            </div>

            <!-- Row 7: Registration Open + Buttons -->
            <div
              class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-4 border-t border-gray-200 dark:border-gray-700"
            >
              <div class="flex items-center">
                <input
                  type="checkbox"
                  id="createRegistrationOpen"
                  name="registration_open"
                  checked
                  class="h-4 w-4 rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500"
                />
                <label
                  for="createRegistrationOpen"
                  class="ml-2 block text-sm text-gray-700 dark:text-gray-300"
                >
                  <i class="fas fa-door-open mr-1"></i>
                  Registration Open
                </label>
              </div>
              <div class="flex items-center gap-3">
                <button
                  type="button"
                  onclick="closeCreateModal()"
                  class="px-5 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors"
                >
                  <i class="fas fa-times mr-1.5"></i>
                  Cancel
                </button>
                <button
                  type="submit"
                  class="px-5 py-2.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-md transition-colors"
                >
                  <i class="fas fa-plus mr-1.5"></i>
                  Create Event
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Modal -->
  <div
    id="editModal"
    class="fixed inset-0 z-50 hidden overflow-y-auto"
    aria-labelledby="modal-title"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0"
    >
      <div
        class="fixed inset-0 bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75 transition-opacity"
        aria-hidden="true"
        onclick="closeEditModal()"
      >
      </div>
      <span
        class="hidden sm:inline-block sm:align-middle sm:h-screen"
        aria-hidden="true">&#8203;</span
      >

      <div
        class="inline-block overflow-hidden text-left align-bottom transition-all transform bg-white dark:bg-gray-800 rounded-lg shadow-xl sm:my-8 sm:align-middle sm:max-w-5xl sm:w-full"
      >
        <div class="px-6 pt-6 pb-4">
          <div class="flex items-center justify-between mb-4">
            <h3
              class="text-lg font-medium text-gray-900 dark:text-white"
              id="modal-title"
            >
              <i class="fas fa-edit mr-2 text-blue-600"></i>
              Edit Event
            </h3>
            <button
              onclick="closeEditModal()"
              class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300"
              type="button"
            >
              <i class="fas fa-times"></i>
            </button>
          </div>

          <form id="editForm" class="mt-2 space-y-4">
            <input type="hidden" id="editEventId" name="id" />

            <!-- Row 1: Title + Slug -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="editTitle"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Title <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="editTitle"
                  name="title"
                  required
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="Event title"
                />
              </div>
              <div>
                <label
                  for="editSlug"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Slug
                </label>
                <input
                  type="text"
                  id="editSlug"
                  name="slug"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="auto-generated"
                />
                <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">
                  Leave blank to auto-generate
                </p>
              </div>
            </div>

            <!-- Row 2: Category + Date -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="editCategory"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Category <span class="text-red-500">*</span>
                </label>
                <select
                  id="editCategory"
                  name="category_id"
                  required
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                >
                  <option value="">Select Category</option>
                  {
                    categories &&
                      categories.map((cat) => (
                        <option value={cat.id}>{cat.name}</option>
                      ))
                  }
                </select>
              </div>
              <div>
                <label
                  for="editDate"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Event Date <span class="text-red-500">*</span>
                </label>
                <input
                  type="date"
                  id="editDate"
                  name="date_event"
                  required
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                />
              </div>
            </div>

            <!-- Row 3: Time + Location -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="editStartTime"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Start Time
                </label>
                <input
                  type="time"
                  id="editStartTime"
                  name="start_time"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                />
              </div>
              <div>
                <label
                  for="editLocation"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Location
                </label>
                <input
                  type="text"
                  id="editLocation"
                  name="location"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="Event location"
                />
              </div>
            </div>

            <!-- Row 4: Quota + Price -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="editQuota"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Quota
                </label>
                <input
                  type="number"
                  id="editQuota"
                  name="quota"
                  min="1"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="Max participants"
                />
              </div>
              <div>
                <label
                  for="editPrice"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Price (Rp)
                </label>
                <input
                  type="number"
                  id="editPrice"
                  name="price"
                  min="0"
                  step="1000"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="0 = Free"
                />
              </div>
            </div>

            <!-- Row 5: Maps + Banner -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="editMaps"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Google Maps Link
                </label>
                <input
                  type="url"
                  id="editMaps"
                  name="maps"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="https://maps.google.com/..."
                />
              </div>
              <div>
                <label
                  for="editBanner"
                  class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >
                  Banner URL
                </label>
                <input
                  type="url"
                  id="editBanner"
                  name="banner"
                  class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                  placeholder="https://example.com/banner.jpg"
                />
              </div>
            </div>

            <!-- Row 6: Description (full width) -->
            <div>
              <label
                for="editDescription"
                class="block text-sm font-medium text-gray-700 dark:text-gray-300"
              >
                Description
              </label>
              <textarea
                id="editDescription"
                name="description"
                rows="3"
                class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                placeholder="Event description"></textarea>
            </div>

            <!-- Row 7: Registration Open + Buttons -->
            <div
              class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-4 border-t border-gray-200 dark:border-gray-700"
            >
              <div class="flex items-center">
                <input
                  type="checkbox"
                  id="editRegistrationOpen"
                  name="registration_open"
                  class="h-4 w-4 rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500"
                />
                <label
                  for="editRegistrationOpen"
                  class="ml-2 block text-sm text-gray-700 dark:text-gray-300"
                >
                  <i class="fas fa-door-open mr-1"></i>
                  Registration Open
                </label>
              </div>
              <div class="flex items-center gap-3">
                <button
                  type="button"
                  onclick="closeEditModal()"
                  class="px-5 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors"
                >
                  <i class="fas fa-times mr-1.5"></i>
                  Cancel
                </button>
                <button
                  type="submit"
                  class="px-5 py-2.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-md transition-colors"
                >
                  <i class="fas fa-save mr-1.5"></i>
                  Update Event
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div
    id="deleteModal"
    class="fixed inset-0 z-50 hidden overflow-y-auto"
    aria-labelledby="delete-modal-title"
    role="dialog"
    aria-modal="true"
  >
    <div
      class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0"
    >
      <div
        class="fixed inset-0 bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75 transition-opacity"
        aria-hidden="true"
        onclick="closeDeleteModal()"
      >
      </div>
      <span
        class="hidden sm:inline-block sm:align-middle sm:h-screen"
        aria-hidden="true">&#8203;</span
      >

      <div
        class="inline-block overflow-hidden text-left align-bottom transition-all transform bg-white dark:bg-gray-800 rounded-lg shadow-xl sm:my-8 sm:align-middle sm:max-w-lg sm:w-full"
      >
        <div class="px-6 pt-6 pb-4">
          <div class="flex items-start">
            <div
              class="flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 dark:bg-red-900/30"
            >
              <i
                class="fas fa-exclamation-triangle text-red-600 dark:text-red-400 text-xl"
              ></i>
            </div>
            <div class="ml-4">
              <h3
                class="text-lg font-medium text-gray-900 dark:text-white"
                id="delete-modal-title"
              >
                Delete Event
              </h3>
              <div class="mt-2">
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  Are you sure you want to delete <span
                    id="deleteEventTitle"
                    class="font-medium text-gray-700 dark:text-gray-300"
                  ></span>? This action cannot be undone.
                </p>
                <p class="mt-2 text-sm text-yellow-600 dark:text-yellow-400">
                  <i class="fas fa-info-circle mr-1"></i>
                  This will also delete all related timelines.
                </p>
              </div>
            </div>
          </div>

          <form id="deleteForm" class="mt-4">
            <input type="hidden" id="deleteEventId" name="id" />
            <div
              class="flex justify-end space-x-3 pt-4 border-t border-gray-200 dark:border-gray-700"
            >
              <button
                type="button"
                onclick="closeDeleteModal()"
                class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors"
              >
                <i class="fas fa-times mr-1"></i>
                Cancel
              </button>
              <button
                type="submit"
                class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-md transition-colors"
              >
                <i class="fas fa-trash mr-1"></i>
                Delete Event
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <style is:global>
    /* Modal styles */
    .modal-backdrop {
      animation: fadeIn 0.2s ease-out;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    /* Smooth transition for modal */
    #createModal,
    #editModal,
    #deleteModal {
      animation: fadeIn 0.2s ease-out;
    }
  </style>

  <script is:inline>
    // Fetch categories for the edit modal
    let categories = [];

    async function loadCategories() {
      try {
        const response = await fetch("/api/categories");
        if (response.ok) {
          categories = await response.json();
          const select = document.getElementById("editCategory");
          if (select) {
            select.innerHTML =
              '<option value="">Select Category</option>' +
              categories
                .map((cat) => `<option value="${cat.id}">${cat.name}</option>`)
                .join("");
          }
        }
      } catch (error) {
        console.error("Error loading categories:", error);
      }
    }

    // Create Modal Functions
    window.openCreateModal = function () {
      document.getElementById("createModal").classList.remove("hidden");
      document.body.style.overflow = "hidden";
      // Reset form
      document.getElementById("createForm").reset();
      document.getElementById("createSlug").value = "";
      document.getElementById("createSlug").dataset.autoGenerated = "false";
      document.getElementById("createRegistrationOpen").checked = true;
    };

    window.closeCreateModal = function () {
      document.getElementById("createModal").classList.add("hidden");
      document.body.style.overflow = "auto";
    };

    // Edit Modal Functions
    window.openEditModal = function (eventId) {
      console.log("Opening edit modal for event ID:", eventId);

      if (!eventId) {
        alert("Invalid event ID");
        return;
      }

      // Fetch event data
      fetch(`/api/admin/events/${eventId}`)
        .then((response) => {
          if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
          }
          return response.json();
        })
        .then((data) => {
          console.log("Event data received:", data);
          if (data && data.data) {
            const event = data.data;
            document.getElementById("editEventId").value = event.id;
            document.getElementById("editTitle").value = event.title || "";
            document.getElementById("editSlug").value = event.slug || "";
            document.getElementById("editCategory").value =
              event.category_id || "";
            document.getElementById("editDate").value = event.date_event || "";
            document.getElementById("editStartTime").value =
              event.start_time || "";
            document.getElementById("editLocation").value =
              event.location || "";
            document.getElementById("editMaps").value = event.maps || "";
            document.getElementById("editQuota").value = event.quota || "";
            document.getElementById("editPrice").value = event.price || "";
            document.getElementById("editBanner").value = event.banner || "";
            document.getElementById("editDescription").value =
              event.description || "";
            document.getElementById("editRegistrationOpen").checked =
              event.registration_open || false;

            document.getElementById("editModal").classList.remove("hidden");
            document.body.style.overflow = "hidden";
          } else {
            alert("Event not found");
          }
        })
        .catch((error) => {
          console.error("Error fetching event:", error);
          alert("Failed to load event data: " + error.message);
        });
    };

    window.closeEditModal = function () {
      document.getElementById("editModal").classList.add("hidden");
      document.body.style.overflow = "auto";
    };

    // Delete Modal Functions
    window.openDeleteModal = function (eventId, eventTitle) {
      console.log("Opening delete modal for event:", eventId, eventTitle);

      if (!eventId) {
        alert("Invalid event ID");
        return;
      }

      document.getElementById("deleteEventId").value = eventId;
      document.getElementById("deleteEventTitle").textContent =
        eventTitle || "Untitled Event";
      document.getElementById("deleteModal").classList.remove("hidden");
      document.body.style.overflow = "hidden";
    };

    window.closeDeleteModal = function () {
      document.getElementById("deleteModal").classList.add("hidden");
      document.body.style.overflow = "auto";
    };

    // Initialize event listeners when DOM is ready
    document.addEventListener("DOMContentLoaded", function () {
      // Load categories
      loadCategories();

      // Create form - auto-generate slug
      const createTitleInput = document.getElementById("createTitle");
      const createSlugInput = document.getElementById("createSlug");

      if (createTitleInput && createSlugInput) {
        createTitleInput.addEventListener("input", function () {
          if (
            !createSlugInput.value ||
            createSlugInput.dataset.autoGenerated === "true"
          ) {
            const slug = this.value
              .toLowerCase()
              .replace(/[^a-z0-9]+/g, "-")
              .replace(/^-+|-+$/g, "");
            createSlugInput.value = slug;
            createSlugInput.dataset.autoGenerated = "true";
          }
        });

        createSlugInput.addEventListener("input", function () {
          this.dataset.autoGenerated = "false";
        });
      }

      // Create form submission
      const createForm = document.getElementById("createForm");
      if (createForm) {
        createForm.addEventListener("submit", async function (e) {
          e.preventDefault();

          const formData = new FormData(this);

          const title = formData.get("title");
          const category_id = formData.get("category_id");
          const date_event = formData.get("date_event");

          if (!title) {
            alert("Title is required");
            return;
          }
          if (!category_id) {
            alert("Category is required");
            return;
          }
          if (!date_event) {
            alert("Event date is required");
            return;
          }

          const data = {
            category_id: category_id,
            title: title,
            slug: formData.get("slug") || undefined,
            description: formData.get("description") || null,
            date_event: date_event,
            start_time: formData.get("start_time") || null,
            location: formData.get("location") || null,
            maps: formData.get("maps") || null,
            quota: formData.get("quota")
              ? parseInt(formData.get("quota"))
              : null,
            price: formData.get("price")
              ? parseInt(formData.get("price"))
              : null,
            banner: formData.get("banner") || null,
            registration_open: formData.get("registration_open") === "on",
          };

          try {
            const response = await fetch("/api/admin/events", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify(data),
            });

            if (response.ok) {
              const result = await response.json();
              if (result.success) {
                window.closeCreateModal();
                window.location.reload();
              } else {
                alert(
                  "Failed to create event: " + (result.error || "Unknown error")
                );
              }
            } else {
              const error = await response.json();
              alert(
                "Failed to create event: " + (error.error || "Unknown error")
              );
            }
          } catch (error) {
            console.error("Error creating event:", error);
            alert("Failed to create event: " + error.message);
          }
        });
      }

      // Edit buttons - using data attributes
      document.querySelectorAll(".edit-btn").forEach((btn) => {
        btn.addEventListener("click", function () {
          const eventId = this.dataset.id;
          window.openEditModal(eventId);
        });
      });

      // Delete buttons - using data attributes
      document.querySelectorAll(".delete-btn").forEach((btn) => {
        btn.addEventListener("click", function () {
          const eventId = this.dataset.id;
          const eventTitle = this.dataset.title;
          window.openDeleteModal(eventId, eventTitle);
        });
      });

      // Edit form submission
      const editForm = document.getElementById("editForm");
      if (editForm) {
        editForm.addEventListener("submit", async function (e) {
          e.preventDefault();

          const formData = new FormData(this);
          const eventId = formData.get("id");

          if (!eventId) {
            alert("Event ID is missing");
            return;
          }

          const data = {
            category_id: formData.get("category_id"),
            title: formData.get("title"),
            slug: formData.get("slug") || undefined,
            description: formData.get("description"),
            date_event: formData.get("date_event"),
            start_time: formData.get("start_time"),
            location: formData.get("location"),
            maps: formData.get("maps"),
            quota: parseInt(formData.get("quota")) || undefined,
            price: parseInt(formData.get("price")) || undefined,
            banner: formData.get("banner"),
            registration_open: formData.get("registration_open") === "on",
          };

          try {
            const response = await fetch(`/api/admin/events/${eventId}`, {
              method: "PUT",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify(data),
            });

            if (response.ok) {
              window.closeEditModal();
              window.location.reload();
            } else {
              const error = await response.json();
              alert(
                "Failed to update event: " + (error.error || "Unknown error")
              );
            }
          } catch (error) {
            console.error("Error updating event:", error);
            alert("Failed to update event: " + error.message);
          }
        });
      }

      // Delete form submission
      const deleteForm = document.getElementById("deleteForm");
      if (deleteForm) {
        deleteForm.addEventListener("submit", async function (e) {
          e.preventDefault();

          const formData = new FormData(this);
          const eventId = formData.get("id");

          if (!eventId) {
            alert("Event ID is missing");
            return;
          }

          try {
            const response = await fetch(`/api/admin/events/${eventId}`, {
              method: "DELETE",
            });

            if (response.ok) {
              window.closeDeleteModal();
              window.location.reload();
            } else {
              const error = await response.json();
              alert(
                "Failed to delete event: " + (error.error || "Unknown error")
              );
            }
          } catch (error) {
            console.error("Error deleting event:", error);
            alert("Failed to delete event: " + error.message);
          }
        });
      }
    });

    // Close modals with Escape key
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") {
        window.closeCreateModal();
        window.closeEditModal();
        window.closeDeleteModal();
      }
    });
  </script>
</AdminLayout>
