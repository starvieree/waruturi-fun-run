---
// src/pages/admin/peserta.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createClient } from '@supabase/supabase-js';

// Initialize Supabase client
const supabaseUrl = import.meta.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseKey);

// Fetch all registrations with event and category data
const { data: registrations, error } = await supabase
  .from('registrations')
  .select(`
    *,
    events (
      id,
      title,
      event_categories (
        id,
        name
      )
    )
  `)
  .order('created_at', { ascending: false });

if (error) {
  console.error('Error fetching registrations:', error);
}

const pesertaData = registrations || [];
---

<AdminLayout title="Admin - Data Peserta">
  <div class="min-h-screen bg-gray-100 dark:bg-gray-900 pt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
          <i class="fas fa-users-cog text-green-600 mr-2"></i>
          Manajemen Peserta
        </h1>
        <div class="flex gap-2">
          <span class="bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 px-4 py-2 rounded-lg text-sm">
            Total: {pesertaData.length} peserta
          </span>
        </div>
      </div>

      <!-- Statistics Cards -->
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
        <div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow">
          <p class="text-2xl font-bold text-gray-900 dark:text-white">{pesertaData.length}</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Total Peserta</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow">
          <p class="text-2xl font-bold text-yellow-600">
            {pesertaData.filter(p => p.payment_status === 'pending').length}
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Menunggu</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow">
          <p class="text-2xl font-bold text-green-600">
            {pesertaData.filter(p => p.payment_status === 'confirmed').length}
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Confirmed</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow">
          <p class="text-2xl font-bold text-red-600">
            {pesertaData.filter(p => p.payment_status === 'rejected').length}
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Ditolak</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow">
          <p class="text-2xl font-bold text-blue-600">
            {pesertaData.filter(p => p.payment_status === 'expired').length}
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Kadaluarsa</p>
        </div>
      </div>

      <!-- Table -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 dark:bg-gray-700">
              <tr>
                <th class="px-4 py-3 text-left">No</th>
                <th class="px-4 py-3 text-left">Nama</th>
                <th class="px-4 py-3 text-left">Email</th>
                <th class="px-4 py-3 text-left">Kategori</th>
                <th class="px-4 py-3 text-left">Jersey</th>
                <th class="px-4 py-3 text-left">Payment</th>
                <th class="px-4 py-3 text-left">Bukti</th>
                <th class="px-4 py-3 text-left">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              {pesertaData.map((peserta, index) => (
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
                  <td class="px-4 py-3 text-gray-500">{index + 1}</td>
                  <td class="px-4 py-3 font-medium text-gray-900 dark:text-white">{peserta.fullname}</td>
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{peserta.email}</td>
                  <td class="px-4 py-3">
                    <span class="inline-block px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">
                      {peserta.events?.event_categories?.name || peserta.events?.title || '-'}
                    </span>
                  </td>
                  <td class="px-4 py-3">
                    <span class="inline-block px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300">
                      {peserta.jersey_size || '-'}
                    </span>
                  </td>
                  <td class="px-4 py-3">
                    <span class={`inline-block px-2 py-1 rounded-full text-xs font-medium ${
                      peserta.payment_status === 'confirmed' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' :
                      peserta.payment_status === 'pending' ? 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400' :
                      peserta.payment_status === 'rejected' ? 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400' :
                      'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300'
                    }`}>
                      {peserta.payment_status === 'confirmed' ? '✅ Lunas' :
                       peserta.payment_status === 'pending' ? '⏳ Menunggu' :
                       peserta.payment_status === 'rejected' ? '❌ Ditolak' :
                       '⏰ Kadaluarsa'}
                    </span>
                  </td>
                  <td class="px-4 py-3">
                    {peserta.payment_proof ? (
                      <a href={peserta.payment_proof} target="_blank" class="text-blue-600 hover:text-blue-800 dark:text-blue-400">
                        <i class="fas fa-file-image mr-1"></i> Lihat
                      </a>
                    ) : (
                      <span class="text-gray-400">-</span>
                    )}
                  </td>
                  <td class="px-4 py-3">
                    <div class="flex gap-2">
                      {peserta.payment_status === 'pending' && (
                        <>
                          <button 
                            onclick=`updatePaymentStatus('${peserta.id}', 'confirmed')`
                            class="bg-green-500 hover:bg-green-600 text-white px-3 py-1 rounded text-xs transition-colors"
                            title="Konfirmasi pembayaran"
                          >
                            <i class="fas fa-check"></i>
                          </button>
                          <button 
                            onclick=`updatePaymentStatus('${peserta.id}', 'rejected')`
                            class="bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded text-xs transition-colors"
                            title="Tolak pembayaran"
                          >
                            <i class="fas fa-times"></i>
                          </button>
                        </>
                      )}
                      <button 
                        onclick=`viewDetail('${peserta.id}')`
                        class="bg-blue-500 hover:bg-blue-600 text-white px-3 py-1 rounded text-xs transition-colors"
                        title="Lihat detail peserta"
                      >
                        <i class="fas fa-eye"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Empty State -->
      {pesertaData.length === 0 && (
        <div class="text-center py-12">
          <i class="fas fa-users text-6xl text-gray-300 dark:text-gray-600 mb-4"></i>
          <p class="text-gray-500 dark:text-gray-400">Belum ada peserta yang mendaftar</p>
        </div>
      )}
    </div>
  </div>

  <!-- Detail Modal -->
  <div id="detailModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center">
    <div class="bg-white dark:bg-gray-800 rounded-lg max-w-2xl w-full mx-4 p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-xl font-bold text-gray-900 dark:text-white">Detail Peserta</h3>
        <button onclick="closeDetail()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>
      <div id="detailContent">
        <div class="text-center py-8">
          <i class="fas fa-spinner fa-spin text-2xl text-gray-400"></i>
          <p class="mt-2 text-gray-500">Memuat data...</p>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script is:inline>
    // Update payment status
    window.updatePaymentStatus = async function(id, status) {
      console.log('🔍 DEBUG - ID yang diterima:', id);
      console.log('🔍 DEBUG - Type ID:', typeof id);
      console.log('🔍 DEBUG - Status:', status);
      
      if (!id) {
        alert('❌ ID tidak ditemukan!');
        return;
      }
  
      const statusLabels = {
        'confirmed': '✅ Lunas',
        'rejected': '❌ Ditolak',
        'pending': '⏳ Menunggu'
      };
  
      if (!confirm(`Yakin ingin mengubah status pembayaran menjadi ${statusLabels[status] || status}?`)) return;
  
      try {
        // Kirim ID sebagai string
        const url = `/api/admin/registration/${id}`;
        console.log('🔍 DEBUG - URL:', url);
        
        const response = await fetch(url, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ payment_status: status })
        });
  
        console.log('🔍 DEBUG - Response status:', response.status);
        
        const result = await response.json();
        console.log('🔍 DEBUG - Response data:', result);
  
        if (response.ok) {
          alert('✅ Status berhasil diupdate!');
          window.location.reload();
        } else {
          alert('❌ Gagal mengupdate status: ' + (result.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('❌ Error:', error);
        alert('❌ Terjadi kesalahan: ' + error.message);
      }
    };
  
    // View detail
    window.viewDetail = async function(id) {
      console.log('🔍 DEBUG - View detail ID:', id);
      console.log('🔍 DEBUG - Type ID:', typeof id);
      
      if (!id) {
        alert('❌ ID tidak ditemukan!');
        return;
      }
  
      const modal = document.getElementById('detailModal');
      const content = document.getElementById('detailContent');
      
      // Show loading
      content.innerHTML = `
        <div class="text-center py-8">
          <i class="fas fa-spinner fa-spin text-2xl text-gray-400"></i>
          <p class="mt-2 text-gray-500">Memuat data...</p>
        </div>
      `;
      modal.classList.remove('hidden');
  
      try {
        const url = `/api/admin/registration/${id}`;
        console.log('🔍 DEBUG - Fetch URL:', url);
        
        const response = await fetch(url);
        console.log('🔍 DEBUG - Response status:', response.status);
        
        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.error || 'Gagal memuat data');
        }
        
        const peserta = await response.json();
        console.log('🔍 DEBUG - Data peserta:', peserta);
        
        content.innerHTML = `
          <div class="space-y-3">
            <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
              <p class="text-sm text-gray-500">ID</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">${peserta.id || '-'}</p>
            </div>
            <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
              <p class="text-sm text-gray-500">Nama Lengkap</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">${peserta.fullname || '-'}</p>
            </div>
            <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
              <p class="text-sm text-gray-500">Email</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">${peserta.email || '-'}</p>
            </div>
            <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
              <p class="text-sm text-gray-500">Telepon</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">${peserta.phone || '-'}</p>
            </div>
            <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
              <p class="text-sm text-gray-500">Jenis Kelamin</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">${peserta.gender || '-'}</p>
            </div>
            <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
              <p class="text-sm text-gray-500">Tanggal Lahir</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">${peserta.birth_date || '-'}</p>
            </div>
            <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
              <p class="text-sm text-gray-500">Ukuran Jersey</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">${peserta.jersey_size || '-'}</p>
            </div>
            <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
              <p class="text-sm text-gray-500">Kontak Darurat</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">${peserta.emergency_contact || '-'}</p>
            </div>
            <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
              <p class="text-sm text-gray-500">Kategori Event</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">${peserta.events?.title || '-'}</p>
            </div>
            <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
              <p class="text-sm text-gray-500">Status Pembayaran</p>
              <p class="text-sm font-medium">
                <span class="inline-block px-2 py-1 rounded-full text-xs font-medium ${
                  peserta.payment_status === 'confirmed' ? 'bg-green-100 text-green-700' :
                  peserta.payment_status === 'pending' ? 'bg-yellow-100 text-yellow-700' :
                  peserta.payment_status === 'rejected' ? 'bg-red-100 text-red-700' :
                  'bg-gray-100 text-gray-700'
                }">
                  ${peserta.payment_status || 'pending'}
                </span>
              </p>
            </div>
            ${peserta.payment_proof ? `
              <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
                <p class="text-sm text-gray-500">Bukti Pembayaran</p>
                <div>
                  <a href="${peserta.payment_proof}" target="_blank" class="text-blue-600 hover:text-blue-800">
                    <i class="fas fa-external-link-alt mr-1"></i> Buka di Tab Baru
                  </a>
                  <img src="${peserta.payment_proof}" alt="Bukti Pembayaran" class="mt-2 max-h-40 rounded-lg shadow-md object-contain border border-gray-200" />
                </div>
              </div>
            ` : ''}
            ${peserta.notes ? `
              <div class="grid grid-cols-2 gap-2 border-b border-gray-200 dark:border-gray-700 pb-2">
                <p class="text-sm text-gray-500">Catatan</p>
                <p class="text-sm text-gray-900 dark:text-white">${peserta.notes}</p>
              </div>
            ` : ''}
            <div class="grid grid-cols-2 gap-2">
              <p class="text-sm text-gray-500">Tanggal Daftar</p>
              <p class="text-sm text-gray-900 dark:text-white">${new Date(peserta.created_at).toLocaleString('id-ID')}</p>
            </div>
          </div>
        `;
      } catch (error) {
        console.error('❌ Error:', error);
        content.innerHTML = `
          <div class="text-center py-8 text-red-600">
            <i class="fas fa-exclamation-circle text-3xl"></i>
            <p class="mt-2 font-medium">${error.message}</p>
            <button onclick="viewDetail('${id}')" class="mt-4 bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg text-sm">
              <i class="fas fa-redo mr-1"></i> Coba Lagi
            </button>
          </div>
        `;
      }
    };
  
    // Close detail modal
    window.closeDetail = function() {
      document.getElementById('detailModal').classList.add('hidden');
    };
  
    // Close modal on outside click
    document.getElementById('detailModal').addEventListener('click', function(e) {
      if (e.target === this) closeDetail();
    });
  
    // Close modal with Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeDetail();
      }
    });
  </script>