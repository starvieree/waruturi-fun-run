---
// src/components/DescriptionPricing.astro
---

<section class="py-16 bg-white dark:bg-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Deskripsi -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Waru Turi Fun Run Kediri 2026</h2>
          <p class="mt-4 text-gray-600 dark:text-gray-300 leading-relaxed">
            Event lomba lari rekreasi bertema <strong>"A Celebration of Movement in Green Scenery"</strong> yang menghadirkan semangat kebersamaan, gaya hidup sehat, dan sportivitas bagi seluruh peserta dari berbagai kalangan.
          </p>
          <p class="mt-4 text-gray-600 dark:text-gray-300 leading-relaxed">
            <strong>Waru Turi Fun Run</strong> berbeda dengan event lari lainnya karena memadukan gaya hidup sehat dengan kepedulian terhadap lingkungan.
          </p>
          <p class="mt-4 text-gray-600 dark:text-gray-300 leading-relaxed">
            Melalui olahraga yang menyenangkan dan aksi nyata <strong>penanaman pohon</strong>, event ini diharapkan memberikan dampak positif yang berkelanjutan serta meningkatkan kesadaran akan pentingnya menjaga kesehatan dan kelestarian alam.
          </p>
          <!-- Highlight -->
          <div class="grid grid-cols-2 gap-4 mt-6">
            <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 text-center">
              <i class="fas fa-heart text-green-600 text-2xl"></i>
              <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-1">Healthy Lifestyle</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">Rekreasi lari yang menyenangkan untuk semua level peserta.</p>
            </div>
            <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 text-center">
              <i class="fas fa-tree text-green-600 text-2xl"></i>
              <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-1">Eco Action</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">Aksi nyata penghijauan & penanaman pohon bersama.</p>
            </div>
          </div>
        </div>
        <!-- Harga & Pendaftar -->
        <div>
          <div class="bg-gray-50 dark:bg-gray-700/50 rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <span class="text-sm font-semibold text-green-600 dark:text-green-400"><i class="fas fa-door-open mr-1"></i> Open Registration</span>
              <span class="text-sm font-semibold text-yellow-600 dark:text-yellow-400"><i class="fas fa-clock mr-1"></i> LIMITED SLOT</span>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <!-- 5K -->
              <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 text-center border-2 border-green-200 dark:border-green-800">
                <span class="text-2xl font-bold text-green-700 dark:text-green-400">5K</span>
                <p class="text-xl font-bold text-gray-900 dark:text-white mt-1">Rp 169.000</p>
                <ul class="mt-3 text-left text-sm text-gray-600 dark:text-gray-400 space-y-1">
                  <li><i class="fas fa-check-circle text-green-500 mr-1"></i> Jersey Official</li>
                  <li><i class="fas fa-check-circle text-green-500 mr-1"></i> Medali Penuh</li>
                  <li><i class="fas fa-check-circle text-green-500 mr-1"></i> BIB Peserta</li>
                  <li><i class="fas fa-check-circle text-green-500 mr-1"></i> Goodie Bag</li>
                  <li><i class="fas fa-check-circle text-green-500 mr-1"></i> Doorprize</li>
                </ul>
                <button class="w-full mt-4 bg-green-600 hover:bg-green-700 text-white font-medium py-2 rounded-lg transition-colors text-sm">
                  Daftar 5K
                </button>
              </div>
              <!-- 10K -->
              <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 text-center border-2 border-yellow-200 dark:border-yellow-800">
                <span class="text-2xl font-bold text-yellow-600 dark:text-yellow-400">10K</span>
                <p class="text-xl font-bold text-gray-900 dark:text-white mt-1">Rp 199.000</p>
                <ul class="mt-3 text-left text-sm text-gray-600 dark:text-gray-400 space-y-1">
                  <li><i class="fas fa-check-circle text-yellow-500 mr-1"></i> Jersey Official</li>
                  <li><i class="fas fa-check-circle text-yellow-500 mr-1"></i> Medali Penuh</li>
                  <li><i class="fas fa-check-circle text-yellow-500 mr-1"></i> BIB Peserta</li>
                  <li><i class="fas fa-check-circle text-yellow-500 mr-1"></i> Goodie Bag</li>
                  <li><i class="fas fa-check-circle text-yellow-500 mr-1"></i> Doorprize</li>
                </ul>
                <button class="w-full mt-4 bg-yellow-500 hover:bg-yellow-600 text-white font-medium py-2 rounded-lg transition-colors text-sm">
                  Daftar 10K
                </button>
              </div>
            </div>
            <!-- Pendaftar Terbaru -->
            <div class="mt-4 p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
              <p class="text-sm text-gray-600 dark:text-gray-300">
                <i class="fas fa-user-check text-blue-500 mr-2"></i>
                <strong>Wilda Natsya</strong> telah mendaftar Waru Turi Fun Run <span class="font-semibold text-green-600">5K</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>