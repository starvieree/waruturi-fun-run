---
// src/components/landing/Peserta.astro
import { createClient } from '@supabase/supabase-js';

// Initialize Supabase client
const supabaseUrl = import.meta.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_ANON_KEY;

if (!supabaseUrl || !supabaseKey) {
  console.error('❌ Missing Supabase environment variables in Peserta Component!');
}

const supabase = createClient(supabaseUrl, supabaseKey);

// Fetch registrations with event and category data
const { data: registrations, error } = await supabase
  .from('registrations')
  .select(`
    *,
    events (
      id,
      title,
      slug,
      description,
      category_id,
      event_categories (
        id,
        name,
        slug
      )
    )
  `)
  .order('created_at', { ascending: false });

// Debug
if (error) {
  console.error('❌ Error fetching registrations:', error);
} else {
  console.log('✅ Total registrations:', registrations?.length || 0);
  console.log('✅ Sample data:', registrations?.[0]);
}

// Fallback data if error
const pesertaData = error || !registrations || registrations.length === 0 ? [] : registrations;

// Get unique categories from events
const categories = [...new Set(
  pesertaData
    .map(p => p.events?.event_categories?.name)
    .filter(Boolean)
)];

// Format date
const formatDate = (date: string) => {
  if (!date) return '';
  return new Date(date).toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
};

// Get gender icon
const getGenderIcon = (gender: string) => {
  if (gender === 'Laki-laki' || gender === 'male') {
    return 'fa-mars';
  } else if (gender === 'Perempuan' || gender === 'female') {
    return 'fa-venus';
  }
  return 'fa-user';
};

// Get jersey size badge color
const getSizeColor = (size: string) => {
  const colors: Record<string, string> = {
    'S': 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',
    'M': 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
    'L': 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400',
    'XL': 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400',
    'XXL': 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400'
  };
  return colors[size] || 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300';
};

// Get payment status badge
const getPaymentStatusColor = (status: string) => {
  const colors: Record<string, string> = {
    'confirmed': 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
    'pending': 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400',
    'failed': 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
    'expired': 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300'
  };
  return colors[status] || 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300';
};

// Get payment status label
const getPaymentStatusLabel = (status: string) => {
  const labels: Record<string, string> = {
    'confirmed': '✅ Lunas',
    'pending': '⏳ Menunggu',
    'failed': '❌ Gagal',
    'expired': '⏰ Kadaluarsa'
  };
  return labels[status] || status || '-';
};
---

<section class="py-16 bg-white dark:bg-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
        Data Peserta
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        Terimakasih telah menjadi bagian dari <strong class="text-green-600">Waru Turi Fun Run 2026</strong>
      </p>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">
        Total Peserta: <span class="font-bold text-green-600">{pesertaData.length}</span>
      </p>
    </div>

    <!-- Search & Filter -->
    <div class="mb-8 flex flex-col md:flex-row gap-4">
      <!-- Search -->
      <div class="flex-1">
        <div class="relative">
          <input 
            id="searchInput"
            type="text" 
            placeholder="Cari nama peserta..." 
            class="w-full px-4 py-2 pl-10 border border-gray-300 dark:border-gray-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 dark:bg-gray-700 dark:text-white"
          />
          <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
        </div>
      </div>
      
      <!-- Filter Kategori -->
      <div class="flex gap-2 flex-wrap">
        <button 
          class="filter-btn px-4 py-2 bg-green-600 text-white rounded-lg text-sm font-medium hover:bg-green-700 transition-colors"
          data-filter="all"
        >
          Semua Kategori
        </button>
        {categories.map(category => (
          <button 
            class="filter-btn px-4 py-2 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg text-sm font-medium hover:bg-green-600 hover:text-white transition-colors"
            data-filter={category}
          >
            {category}
          </button>
        ))}
      </div>
    </div>

    <!-- Table -->
    <div class="bg-gray-50 dark:bg-gray-900/50 rounded-xl overflow-hidden shadow-md">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-green-600 dark:bg-green-800 text-white">
            <tr>
              <th class="px-4 py-3 text-left">No</th>
              <th class="px-4 py-3 text-left">Nama</th>
              <th class="px-4 py-3 text-left">Email</th>
              <th class="px-4 py-3 text-left">Jersey Size</th>
              <th class="px-4 py-3 text-left">Kategori</th>
              <th class="px-4 py-3 text-left">Payment</th>
              <th class="px-4 py-3 text-left">Tanggal Daftar</th>
            </tr>
          </thead>
          <tbody id="participantTableBody" class="divide-y divide-gray-200 dark:divide-gray-700">
            {pesertaData.length > 0 ? (
              pesertaData.map((peserta, index) => (
                <tr 
                  class="hover:bg-gray-100 dark:hover:bg-gray-700/50 transition-colors participant-row"
                  data-name={peserta.fullname?.toLowerCase() || ''}
                  data-category={peserta.events?.event_categories?.name || ''}
                >
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{index + 1}</td>
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-2">
                      <i class={`fas ${getGenderIcon(peserta.gender)} text-gray-400 text-xs`}></i>
                      <span class="font-medium text-gray-900 dark:text-white">{peserta.fullname || '-'}</span>
                    </div>
                  </td>
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{peserta.email || '-'}</td>
                  <td class="px-4 py-3">
                    <span class={`inline-block px-2 py-1 rounded-full text-xs font-medium ${getSizeColor(peserta.jersey_size)}`}>
                      {peserta.jersey_size || '-'}
                    </span>
                  </td>
                  <td class="px-4 py-3">
                    <span class="inline-block px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">
                      {peserta.events?.event_categories?.name || peserta.events?.title || '-'}
                    </span>
                  </td>
                  <td class="px-4 py-3">
                    <span class={`inline-block px-2 py-1 rounded-full text-xs font-medium ${getPaymentStatusColor(peserta.payment_status)}`}>
                      {getPaymentStatusLabel(peserta.payment_status)}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
                    {formatDate(peserta.created_at)}
                  </td>
                </tr>
              ))
            ) : (
              <tr>
                <td colspan="7" class="px-4 py-8 text-center text-gray-500 dark:text-gray-400">
                  <i class="fas fa-users text-3xl mb-2 block"></i>
                  Belum ada peserta yang mendaftar
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Error State -->
    {error && (
      <div class="mt-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg">
        <p class="text-red-600 dark:text-red-400 text-center">
          <i class="fas fa-exclamation-circle mr-2"></i>
          Gagal memuat data peserta. Silakan refresh halaman.
        </p>
      </div>
    )}

    <!-- Recent Registrant -->
    {pesertaData.length > 0 && (
      <div class="mt-6 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800 rounded-lg">
        <p class="text-sm text-gray-600 dark:text-gray-300">
          <i class="fas fa-user-check text-blue-500 mr-2"></i>
          <strong>{pesertaData[0]?.fullname || 'Peserta'}</strong> telah mendaftar Waru Turi Fun Run <span class="font-semibold text-green-600">{pesertaData[0]?.events?.event_categories?.name || pesertaData[0]?.events?.title || '-'}</span>
        </p>
      </div>
    )}

    <!-- Statistics -->
    {pesertaData.length > 0 && (
      <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-green-600 dark:text-green-400">{pesertaData.length}</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">Total Peserta</p>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-blue-600 dark:text-blue-400">
            {pesertaData.filter(p => p.events?.event_categories?.name === '5K').length}
          </p>
          <p class="text-xs text-gray-500 dark:text-gray-400">Peserta 5K</p>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-orange-600 dark:text-orange-400">
            {pesertaData.filter(p => p.events?.event_categories?.name === '10K').length}
          </p>
          <p class="text-xs text-gray-500 dark:text-gray-400">Peserta 10K</p>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-green-600 dark:text-green-400">
            {pesertaData.filter(p => p.payment_status === 'confirmed').length}
          </p>
          <p class="text-xs text-gray-500 dark:text-gray-400">Lunas</p>
        </div>
      </div>
    )}
  </div>
</section>

<script is:inline>
  // Search and Filter functionality
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('searchInput');
    const rows = document.querySelectorAll('.participant-row');
    const filterButtons = document.querySelectorAll('.filter-btn');

    const filterRows = () => {
      const searchTerm = searchInput?.value.toLowerCase() || '';
      const activeFilter = document.querySelector('.filter-btn.bg-green-600')?.dataset.filter || 'all';
      
      rows.forEach(row => {
        const name = row.dataset.name || '';
        const category = row.dataset.category || '';
        
        const matchesSearch = name.includes(searchTerm);
        const matchesFilter = activeFilter === 'all' || category === activeFilter;
        
        row.style.display = (matchesSearch && matchesFilter) ? '' : 'none';
      });
    };

    // Search handler
    searchInput?.addEventListener('input', filterRows);

    // Filter handler
    filterButtons.forEach(button => {
      button.addEventListener('click', function() {
        // Reset all filter buttons
        filterButtons.forEach(btn => {
          btn.classList.remove('bg-green-600', 'text-white');
          btn.classList.add('bg-gray-200', 'dark:bg-gray-700', 'text-gray-700', 'dark:text-gray-300');
        });
        
        // Activate clicked button
        this.classList.remove('bg-gray-200', 'dark:bg-gray-700', 'text-gray-700', 'dark:text-gray-300');
        this.classList.add('bg-green-600', 'text-white');
        
        filterRows();
      });
    });
  });
</script>