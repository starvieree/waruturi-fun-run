---
// src/components/StatisticsBenefits.astro
---

<section class="py-16 bg-white dark:bg-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="text-center bg-gray-50 dark:bg-gray-700/50 rounded-xl p-6">
          <span class="text-4xl font-bold text-green-600 dark:text-green-400">1</span>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">DAY EVENT</p>
        </div>
        <div class="text-center bg-gray-50 dark:bg-gray-700/50 rounded-xl p-6">
          <span class="text-4xl font-bold text-green-600 dark:text-green-400">5K</span>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">RUN CATEGORY</p>
        </div>
        <div class="text-center bg-gray-50 dark:bg-gray-700/50 rounded-xl p-6">
          <span class="text-4xl font-bold text-green-600 dark:text-green-400">10K</span>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">RUN CATEGORY</p>
        </div>
      </div>
  
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white text-center mb-8">Kenapa Anda Harus Ikut Event ini?</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
        <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 text-center">
          <i class="fas fa-id-card text-3xl text-green-600 dark:text-green-400"></i>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-2">Nomor BIB</p>
        </div>
        <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 text-center">
          <i class="fas fa-tshirt text-3xl text-green-600 dark:text-green-400"></i>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-2">Jersey Official</p>
        </div>
        <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 text-center">
          <i class="fas fa-medal text-3xl text-green-600 dark:text-green-400"></i>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-2">Finisher Medal</p>
        </div>
        <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 text-center">
          <i class="fas fa-gift text-3xl text-green-600 dark:text-green-400"></i>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-2">Goodie Bag</p>
        </div>
        <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 text-center">
          <i class="fas fa-trophy text-3xl text-green-600 dark:text-green-400"></i>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-2">Doorprize</p>
        </div>
      </div>
    </div>
  </section>