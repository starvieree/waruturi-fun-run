---
// src/components/Route.astro
---

<section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white text-center mb-4">PETA RUTE LARI</h3>
      <p class="text-center text-gray-600 dark:text-gray-400 mb-8">Kenali rute tantanganmu dan nikmati pemandangan Bendung Waruturi</p>
  
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Rute 5K -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
          <h4 class="text-xl font-bold text-green-700 dark:text-green-400 mb-2">Route 5K (Fun Run)</h4>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Plan Route: Start (Lap. Bendungan Waru Turi) - Kantor Jasa Tirta - Jembatan Utama - Ujung Jembatan Utama ke Kanan - Jembatan Kedua ke Kiri - Patung Badak ke Kanan - Pintu Gerbang Waduk Sisi Barat ke Kiri - Simpang Tiga Jabon Gg 8 ke Kanan - Simpang Tiga Jabon Gg 8 ke Kanan - Pintu Gerbang Waduk Sisi Barat - Jembatan Utama ke Kanan - Kantor Jasa Tirta - Finish</p>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div><span class="font-semibold">Start:</span> Bendung Gerak Waru Turi</div>
            <div><span class="font-semibold">Finish:</span> Bendung Gerak Waru Turi</div>
            <div><span class="font-semibold">COT:</span> 1 Jam 30 Menit</div>
            <div><span class="font-semibold">Water Station:</span> KM 2.5</div>
          </div>
        </div>
        <!-- Rute 10K -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
          <h4 class="text-xl font-bold text-yellow-600 dark:text-yellow-400 mb-2">Route 10K (Fun Run)</h4>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Plan Route: Start (Lap. Bendungan Waru Turi) - Kantor Jasa Tirta - Jembatan Utama - Ujung Jembatan Utama ke Kanan - Jembatan Kedua ke Kiri - Patung Badak ke Kanan - Pintu Gerbang Waduk Sisi Barat Lurus - Perempatan Dusun Tanjung - Simpang Empat Desa Ngabak ke Kiri - Simpang Empat Kelurahan Dermo ke Kiri - Simpang Empat Jl. Merbabu Lurus - Jabon Gg 4 - Jabon Gg 5 - Simpang Tiga Jabon Gg 8 ke Kiri - Pintu Gerbang Waduk - Patung Badak ke Kiri - Jembatan Kedua ke Kanan - Jembatan Utama - Area Food Court ke Kanan - Jembatan Kecil ke Kanan - Finish</p>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div><span class="font-semibold">Start:</span> Bendung Gerak Waru Turi</div>
            <div><span class="font-semibold">Finish:</span> Bendung Gerak Waru Turi</div>
            <div><span class="font-semibold">COT:</span> 2 Jam</div>
            <div><span class="font-semibold">Water Station:</span> KM 2.5, KM 5, KM 7.5</div>
          </div>
        </div>
      </div>
    </div>
  </section>